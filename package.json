{
  "name": "ibasho-do-cra",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "generate:client": "turbo run generate:client",
    "depcruise": "depcruise apps/*/src apps/*/server --config .dependency-cruiser.cjs"
  },
  "devDependencies": {
    "turbo": "^2.10.0",
    "typescript": "^5.6.0",
    "dependency-cruiser": "^16.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "vue-demi",
      "unrs-resolver",
      "better-sqlite3",
      "@nestjs/core"
    ]
  }
}
